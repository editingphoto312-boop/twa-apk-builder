name: 🤖 Build TWA APK

on:
  repository_dispatch:
    types: [build-apk]

permissions:
  contents: write

env:
  APP_URL:  "${{ github.event.client_payload.url }}"
  APP_NAME: "${{ github.event.client_payload.appName }}"
  PKG_ID:   "${{ github.event.client_payload.packageId }}"

jobs:
  build:
    name: Generate & Release APK
    runs-on: ubuntu-latest
    timeout-minutes: 30

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Set up Node.js 20
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Set up Android SDK
        uses: android-actions/setup-android@v3

      - name: Install Android platform + build tools
        run: |
          sdkmanager --update
          sdkmanager "platforms;android-34" "build-tools;34.0.0"

      - name: Install Bubblewrap CLI
        run: npm install -g @bubblewrap/cli

      - name: Generate Android keystore
        run: |
          KS_PASS="${{ secrets.KEYSTORE_PASSWORD }}"
          KS_PASS="${KS_PASS:-android}"
          echo "KEYSTORE_PASS=$KS_PASS" >> $GITHUB_ENV

          keytool -genkeypair \
            -v \
            -keystore "$GITHUB_WORKSPACE/android.keystore" \
            -alias android \
            -keyalg RSA \
            -keysize 2048 \
            -validity 10000 \
            -storepass "$KS_PASS" \
            -keypass  "$KS_PASS" \
            -dname "CN=TWA Builder, OU=TWA, O=TWA, L=City, S=State, C=US"

          echo "✅ Keystore created"

      - name: Generate twa-manifest.json
        run: |
          node - <<'EOF'
          const fs  = require('fs');
          const url = process.env.APP_URL;
          const parsed = new URL(url);
          const host   = parsed.host;

          const pkgId = process.env.PKG_ID ||
            'com.twa.' + host.replace(/[^a-z0-9]/gi, '').toLowerCase();

          const appName = process.env.APP_NAME || 'TWA App';

          const manifest = {
            packageId:   pkgId,
            host,
            name:         appName,
            launcherName: appName.substring(0, 12),
            display:      'standalone',
            orientation:  'default',
            themeColor:          '#FFFFFF',
            navigationColor:     '#000000',
            navigationColorDark: '#000000',
            backgroundColor:     '#FFFFFF',
            startUrl:  '/',
            iconUrl:        url.replace(/\/$/, '') + '/icon-512x512.png',
            maskableIconUrl:url.replace(/\/$/, '') + '/icon-512x512.png',
            shortcuts: [],
            appVersion:     '1',
            appVersionCode: 1,
            signingKey: {
              path:  '../../android.keystore',
              alias: 'android'
            },
            splashScreenFadeOutDuration: 300,
            enableNotifications:        false,
            enableSiteSettingsShortcut: true,
            isChromeOSOnly: false,
            isMetaQuest:    false,
            fullScopeUrl:   url.replace(/\/$/, '') + '/',
            minSdkVersion:  19,
            targetSdkVersion: 34,
            generatorApp:   'bubblewrap-cli',
            webManifestUrl: url.replace(/\/$/, '') + '/manifest.json',
            fallbackType:   'customtabs',
            features:       {},
            alphaDependencies: { enabled: false }
          };

          fs.writeFileSync('twa-manifest.json', JSON.stringify(manifest, null, 2));
          console.log('✅ twa-manifest.json generated');
          console.log('   Package ID:', pkgId);
          console.log('   Host:      ', host);
          console.log('   App name:  ', appName);
          EOF

      - name: Configure Bubblewrap SDK paths (non-interactive)
        run: |
          JAVA_HOME_PATH="${JAVA_HOME}"
          ANDROID_SDK_PATH="${ANDROID_SDK_ROOT:-$ANDROID_HOME}"

          echo "Java home:   $JAVA_HOME_PATH"
          echo "Android SDK: $ANDROID_SDK_PATH"

          mkdir -p ~/.bubblewrap
          printf '{"jdkPath":"%s","androidSdkPath":"%s"}\n' \
            "$JAVA_HOME_PATH" "$ANDROID_SDK_PATH" \
            > ~/.bubblewrap/config.json

          echo "✅ Bubblewrap config written:"
          cat ~/.bubblewrap/config.json

      - name: Build APK with Bubblewrap
        run: |
          mkdir -p twa-build
          cp twa-manifest.json twa-build/
          cd twa-build

          # 'yes' command auto-answers ALL prompts with "y" (JDK/SDK install questions)
          yes | bubblewrap build --skipPwaValidation || true

          # Verify APK was actually created
          APK_CHECK=$(find . -name "*.apk" | head -1)
          if [ -z "$APK_CHECK" ]; then
            echo "❌ Build failed — no APK produced"
            exit 1
          fi
          echo "✅ APK found: $APK_CHECK"

      - name: Locate APK
        run: |
          APK=$(find . -name "*.apk" | head -1)
          if [ -z "$APK" ]; then
            echo "❌ No APK found — check the build logs above."
            exit 1
          fi
          SAFE=$(echo "$APP_NAME" | tr ' ' '_' | tr -cd '[:alnum:]_-')
          FINAL="${SAFE}.apk"
          cp "$APK" "$FINAL"
          echo "APK_FILE=$FINAL" >> $GITHUB_ENV
          echo "APK_LABEL=$SAFE" >> $GITHUB_ENV
          echo "✅ APK ready: $FINAL"

      - name: Delete old 'latest' release (if exists)
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh release delete latest --yes 2>/dev/null || true
          git push origin --delete refs/tags/latest 2>/dev/null || true

      - name: Create GitHub Release and upload APK
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          TIMESTAMP=$(date -u '+%Y-%m-%d %H:%M UTC')

          gh release create latest "${{ env.APK_FILE }}" \
            --repo "${{ github.repository }}" \
            --title "Latest Build — ${APP_NAME}" \
            --notes "## ✅ APK Ready

          | Field | Value |
          |---|---|
          | **App Name** | ${APP_NAME} |
          | **Source URL** | ${APP_URL} |
          | **Built at** | ${TIMESTAMP} |

          ### How to install
          1. Download the \`.apk\` file below
          2. Enable *Install from unknown sources* on your Android device
          3. Open the file to install" \
            --latest

          echo "✅ Release: https://github.com/${{ github.repository }}/releases/tag/latest"

      - name: Job summary
        run: |
          echo "## ✅ APK Build Complete" >> $GITHUB_STEP_SUMMARY
          echo "| | |" >> $GITHUB_STEP_SUMMARY
          echo "|---|---|" >> $GITHUB_STEP_SUMMARY
          echo "| **App** | $APP_NAME |" >> $GITHUB_STEP_SUMMARY
          echo "| **URL** | $APP_URL |" >> $GITHUB_STEP_SUMMARY
          echo "| **Release** | [Download APK](https://github.com/${{ github.repository }}/releases/tag/latest) |" >> $GITHUB_STEP_SUMMARY
